# ─── Backend ───
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbName>?retryWrites=true&w=majority
PORT=5000

# Optional: restrict CORS to your frontend domain in production
# CORS_ORIGIN=https://your-frontend.vercel.app

# ─── Frontend (Vite) ───
# Set this in production to point to your deployed backend
# VITE_API_URL=https://your-backend.onrender.com
